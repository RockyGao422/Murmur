{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["src/shared/*"],
      "@background/*": ["src/background/*"],
      "@popup/*": ["src/popup/*"],
      "@options/*": ["src/options/*"],
      "@calculator/*": ["src/calculator/*"],
      "@export/*": ["src/export/*"]
    },
    "types": ["chrome"]
  },
  "include": ["src/**/*.js"],
  "exclude": ["node_modules"]
}
