{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://murmur.app/schemas/raw-event.json",
  "title": "RawEvent",
  "description": "A raw detection event before matching and sessionization. Generated by platform detectors and consumed by ToolMatcher.",
  "type": "object",
  "properties": {
    "event_id": { "type": "string", "description": "Local unique event identifier" },
    "platform": {
      "type": "string",
      "enum": ["macos", "android", "browser"],
      "description": "Source platform"
    },
    "event_type": {
      "type": "string",
      "enum": [
        "foreground", "background",
        "tab_active", "tab_inactive",
        "navigation", "idle", "close"
      ],
      "description": "Type of detection event"
    },
    "timestamp": { "type": "string", "format": "date-time", "description": "Event timestamp" },
    "app_name": { "type": "string", "description": "Application display name" },
    "bundle_id": { "type": "string", "description": "macOS bundle identifier" },
    "package_name": { "type": "string", "description": "Android package name" },
    "domain": { "type": "string", "description": "Browser domain (hostname only)" },
    "url_pattern": { "type": "string", "description": "URL pattern without sensitive parts" },
    "window_title": { "type": "string", "description": "Window title (not persisted as plaintext)" },
    "tab_id": { "type": "integer", "description": "Browser tab identifier" },
    "window_id": { "type": "integer", "description": "Browser window identifier" }
  },
  "required": ["event_id", "platform", "event_type", "timestamp"]
}
