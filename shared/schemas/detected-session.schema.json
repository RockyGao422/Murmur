{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://murmur.app/schemas/detected-session.json",
  "title": "DetectedSession",
  "description": "An auto-detected AI usage session generated by the platform detector.",
  "type": "object",
  "properties": {
    "id": { "type": "string", "description": "Local unique identifier (UUID)" },
    "source_platform": {
      "type": "string",
      "enum": ["macos", "android", "browser"],
      "description": "Detection source platform"
    },
    "source_kind": {
      "type": "string",
      "enum": ["app", "web"],
      "description": "App or web-based detection"
    },
    "detector_id": {
      "type": "string",
      "description": "Detector identifier, e.g. macos.workspace, android.usagestats, browser.tabs"
    },
    "tool_id": { "type": "string", "description": "Matched tool ID from Tool Catalog" },
    "tool_name": { "type": "string", "description": "Snapshot of tool display name at detection time" },
    "raw_app_name": { "type": "string", "description": "Original application name" },
    "raw_bundle_id": { "type": "string", "description": "macOS bundle identifier" },
    "raw_package_name": { "type": "string", "description": "Android package name" },
    "raw_domain": { "type": "string", "description": "Browser domain name" },
    "raw_url_pattern": { "type": "string", "description": "URL pattern without sensitive full URL" },
    "window_title_hash": { "type": "string", "description": "Optional SHA-256 hash of window title" },
    "started_at": { "type": "string", "format": "date-time", "description": "Session start timestamp" },
    "ended_at": { "type": "string", "format": "date-time", "description": "Session end timestamp" },
    "active_seconds": { "type": "integer", "minimum": 0, "description": "Active duration in seconds" },
    "idle_seconds": { "type": "integer", "minimum": 0, "description": "Idle duration in seconds (P1)" },
    "local_date": { "type": "string", "format": "date", "description": "Local date YYYY-MM-DD" },
    "timezone": { "type": "string", "description": "IANA timezone" },
    "is_night": { "type": "boolean", "description": "Whether session occurred during night hours" },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Detection confidence score"
    },
    "status": {
      "type": "string",
      "enum": ["pending", "completed", "ignored", "merged", "suspected"],
      "description": "Session processing status"
    },
    "merged_into_session_id": { "type": "string", "description": "Target session ID if merged" },
    "prompt_count": { "type": "integer", "minimum": 0, "description": "Optional prompt send count (no content)" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "required": [
    "id", "source_platform", "source_kind", "detector_id",
    "started_at", "ended_at", "active_seconds", "local_date",
    "confidence", "status", "created_at", "updated_at"
  ]
}
